# Postgres — Supabase, via the session pooler (IPv4-compatible; Supabase's
# direct-connection host is IPv6-only and unreachable from most networks).
# Get this from Supabase dashboard -> Connect -> Session pooler.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true"

# Redis — optional. Free tier at upstash.com. Leave unset and the cache
# layer degrades gracefully to "no cache" (see src/lib/cache.ts).
REDIS_URL="redis://localhost:6379"

# Session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Public site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Supabase Storage — used for admin product-image uploads (src/lib/supabase-storage.ts).
# Same Supabase project as DATABASE_URL above. Setup:
#   1. Dashboard -> Storage -> New bucket -> name it "product-images", set it Public.
#   2. Dashboard -> Settings -> API -> copy the Project URL and the two keys below.
# NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are safe to expose to the
# browser (the anon key can only use the signed upload slot the server already issued).
# SUPABASE_SERVICE_ROLE_KEY must stay server-only — never prefix it with NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Optional — card payments via Paymob. Leave unset to use the sandbox mock
# gateway (checkout completes instantly, no real charge).
# PAYMOB_API_KEY=""
# PAYMOB_INTEGRATION_ID=""
# PAYMOB_IFRAME_ID=""
# PAYMOB_HMAC_SECRET=""

# Optional — real courier shipments via Bosta. Leave unset to use a
# locally generated mock tracking number instead.
# BOSTA_API_KEY=""

# Store owner's phone — fallback admin-alert channel if Telegram isn't set up.
# ADMIN_ALERT_PHONE=""

# New-order alerts via Telegram — genuinely free, no trial, no limits.
# Setup: message @BotFather on Telegram -> /newbot -> paste the token below.
# Then message your new bot anything, and run `npm run telegram:chat-id`
# to get the chat_id to paste below.
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""

# Optional — real WhatsApp/SMS delivery via Twilio (customer-facing
# messages). Leave unset and those just log to the console instead of
# sending. Trial-credit based, not free forever.
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_WHATSAPP_FROM=""   # e.g. "whatsapp:+14155238886" (Twilio sandbox number for testing)
# TWILIO_SMS_FROM=""        # e.g. "+1XXXXXXXXXX" — used only if TWILIO_WHATSAPP_FROM is unset
